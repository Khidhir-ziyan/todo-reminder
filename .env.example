# Telegram Bot Token (dapat dari @BotFather)
TELEGRAM_BOT_TOKEN=

# Email untuk kirim reminder
# Untuk Gmail: kosongkan SMTP_HOST, gunakan App Password
# Untuk email kampus/custom: isi SMTP_HOST dan SMTP_PORT
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_HOST=                    # Contoh: mail.cakrawala.ac.id
SMTP_PORT=587                 # 587 (TLS) atau 465 (SSL)

# Email tujuan reminder
REMINDER_EMAIL=your-email@gmail.com

# Google Cloud Speech-to-Text API Key (opsional, untuk voice input)
# Atau set GOOGLE_APPLICATION_CREDENTIALS ke path service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Timezone
TZ=Asia/Jakarta
