# Telegram Bot Token (dapat dari @BotFather)
TELEGRAM_BOT_TOKEN=

# Email SMTP Configuration (sesuai PRD)
SMTP_HOST=smtp.gmail.com        # Contoh: mail.cakrawala.ac.id
SMTP_PORT=587                   # 587 (TLS) atau 465 (SSL)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password         # Untuk Gmail: gunakan App Password
SMTP_FROM="Reminder Bot <your-email@gmail.com>"

# Email tujuan default (bisa di-override per user via /setemail)
DEFAULT_EMAIL_TARGET=your-email@gmail.com

# Mistral AI API Key (opsional, untuk NLP yang lebih baik)
MISTRAL_API_KEY=

# Google Cloud Speech-to-Text API Key (opsional, untuk voice input)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Timezone
TZ=Asia/Jakarta
